{
  "name": "coinflow-docs-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Closed-loop, model-agnostic optimizer for agent-integrable Coinflow docs.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "mock": "tsx src/mock/api/main.ts",
    "smoke": "tsx src/mock/api/smoke.ts",
    "drive:za": "tsx src/verifier/drive-za.ts",
    "verify": "tsx src/verifier/run.ts",
    "implement": "tsx src/harness/run-implementer.ts",
    "panel": "tsx src/harness/run-panel.ts",
    "eval": "tsx src/loop/run-optimize.ts",
    "probe": "tsx src/verifier/live-probe.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
