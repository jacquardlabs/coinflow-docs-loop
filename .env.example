# Copy to `.env` and fill in keys for whichever models you want to run live.
# Any mechanism works — this file, exported shell vars, or a secrets manager
# (e.g. `doppler run -- pnpm implement claude za-guide.v0`). Exported vars win over this file.
# The offline mock provider needs no keys at all.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Self-hosted / OpenAI-compatible endpoint (the `local` provider):
# LOCAL_API_KEY=
# LOCAL_BASE_URL=http://localhost:8000/v1
# LOCAL_MODEL=my-model
